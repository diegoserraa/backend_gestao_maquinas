### =========================
### ALTERAR STATUS
### =========================
PATCH http://localhost:3000/ordens-servico/56/status
Content-Type: application/json

{
  "status": "EM_ANDAMENTO"
}


### =========================
### ALTERAR PRIORIDADE
### =========================
PATCH http://localhost:3000/ordens-servico/56/prioridade
Content-Type: application/json

{
  "prioridade": "MEDIA"
}



### =========================
### ATRIBUIR TÉCNICO
### =========================
PATCH http://localhost:3000/ordens-servico/56/tecnico
Content-Type: application/json

{
  "id_tecnico": 1
}


### =========================
### FINALIZAR ORDEM DE SERVIÇO
### =========================
PATCH http://localhost:3000/ordens-servico/56/finalizar
Content-Type: application/json

{
  "resolucao": "Substituição do rolamento do eixo principal"
}